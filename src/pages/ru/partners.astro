          { category: "Корпоративные системы", sub: ["Управление бизнес-процессами (BPM)", "Система управления контентом (CMS)", "E-commerce / розница (подписки / дистрибуция)", "Проекты и совместная работа (PM / Collaboration)"] },
          { category: "Отраслевые решения", sub: ["Финансовые услуги", "ИТ и ПО"] }
        ],
        contact: "arnaud@ebs-vanuatu.com",
        certified: false,
        featured: false
      }
    ]
  }
];

// ✅ Normalizer
const normalize = (s: string) => (s || "").trim();

const filterCategoriesMap = {
  "Типы услуг": new Set<string>(),
  "Корпоративные системы": new Set<string>(),
  "Отраслевые решения": new Set<string>(),
};

partnersByContinent.forEach((region) => {
  region.partners.forEach((partner) => {
    partner.services.forEach((service) => {
      const cat = normalize(service.category);

      // Only collect sub-items for Корпоративные системы / Отраслевые решения
      if (cat === "Корпоративные системы") {
        service.sub.forEach((sub) => {
          const item = normalize(sub);
          if (item) filterCategoriesMap["Корпоративные системы"].add(item);
        });
        return;
      }

      if (cat === "Отраслевые решения") {
        service.sub.forEach((sub) => {
          const item = normalize(sub);
          if (item) filterCategoriesMap["Отраслевые решения"].add(item);
        });
        return;
      }

      // Everything else goes under "Типы услуг": the category itself + its sub-items
      if (cat && cat !== "Типы услуг") {
        filterCategoriesMap["Типы услуг"].add(cat);
      }
      service.sub.forEach((sub) => {
        const item = normalize(sub);
        if (item) filterCategoriesMap["Типы услуг"].add(item);
      });
    });
  });
});

// Convert to array and remove empties / self references
const filterCategories = Object.entries(filterCategoriesMap).map(([title, set]) => ({
  title,
  items: Array.from(set).filter((it) => it && it !== title),
}));

// Sidebar counts per sub-item (e.g., Deployment, CRM, ERP, …)
const itemCountMap: Record<string, number> = {};
partnersByContinent.forEach((region) => {
  region.partners.forEach((p) => {
    const seen = new Set<string>();
    p.services.forEach((s) => {
      s.sub.forEach((raw) => {
        const sub = (raw || "").trim();
        if (!sub || seen.has(sub)) return;
        seen.add(sub);
        itemCountMap[sub] = (itemCountMap[sub] || 0) + 1;
      });
    });
  });
});

// Country list
const countries = Array.from(
  new Set(
    partnersByContinent.flatMap((region) =>
      region.partners.map((p) => p.location.split("·")[0].trim()),
    ),
  ),
);

// Flatten services (kept here if you need it later)
const serviceCountMap = {};
partnersByContinent.forEach((region) => {
  region.partners.forEach((p) => {
    p.services.forEach((s) => {
      serviceCountMap[s] = (serviceCountMap[s] || 0) + 1;
    });
  });
});
