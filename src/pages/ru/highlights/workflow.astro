---
import PageHeader from "../../../components/PageHeader.astro";
import Layout from "../../../layouts/Layout.astro";
import { getPage } from "../../../utils";

const page = await getPage("workflow");

const title = page.title;
const description = page.description;
const keywords = page.keywords;
---

<Layout title={title} description={description} keywords={keywords}>
  <PageHeader title={title}>
    <span slot="description" set:html={description}></span>
  </PageHeader>
  <!-- Start Highlights -->
  <section class="section">
    <div class="container">
      <div class="row align-items-top ">
        <div class="col-lg-5 col-md-5">
          <div class="section-title">
            <h5 class="mb-4">Создание workflow из <span class="text-primary">триггеров и действий</span></h5>
            <p class="text-muted">Рабочий процесс NocoBase состоит из одного триггера и последовательности узлов-действий. Триггер запускает процесс, а действия выполняются шаг за шагом.</p>
          </div>
        </div><!--end col-->
        <div class="col-lg-7">
          <div class="card rounded border-0 shadow ms-lg-5">
            <video controls class="rounded shadow">
              <source src="https://static-docs.nocobase.com/WF-5.1-EN.mp4" type="video/mp4">
            </video>
          </div>
        </div><!--end col-->
      </div><!--end row-->
      <div class="row align-items-top mt-100">
        <div class="col-lg-5 col-md-5">
          <div class="section-title">
            <h5 class="mb-4"><span class="text-primary">Проверка логики</span> перед отправкой формы</h5>
            <p class="text-muted">События преддействия вызываются до выполнения действия. Например, при отправке заказа менеджером система должна проверить остатки на складе.<br>Если товара не хватает, workflow автоматически блокирует отправку и уведомляет пользователя, предотвращая излишние продажи и ошибки.</p>
          </div>
        </div><!--end col-->
        <div class="col-lg-7">
          <div class="card rounded border-0 shadow ms-lg-5">
            <video controls class="rounded shadow">
              <source src="https://static-docs.nocobase.com/WF-5.2-EN.mp4" type="video/mp4">
            </video>
          </div>
        </div><!--end col-->
      </div><!--end row-->
      <div class="row align-items-top mt-100">
        <div class="col-lg-5 col-md-5">
          <div class="section-title">
            <h5 class="mb-4">Передача данных между <span class="text-primary">несколькими источниками</span></h5>
            <p class="text-muted">Если приложение NocoBase использует несколько источников данных, workflow может согласовывать их логику на бэкенде. Например, при создании нового заказа в ERP статус клиента в CRM можно автоматически повышать до "Оплатил".</p>
          </div>
        </div><!--end col-->
        <div class="col-lg-7">
          <div class="card rounded border-0 shadow ms-lg-5">
            <video controls class="rounded shadow">
              <source src="https://static-docs.nocobase.com/DS-1.3-EN.mp4" type="video/mp4">
            </video>
          </div>
        </div><!--end col-->
      </div><!--end row-->
      <div class="row align-items-top mt-100">
        <div class="col-lg-5 col-md-5">
          <div class="section-title">
            <h5 class="mb-4">Получение <span class="text-primary">внешних данных</span> через webhook</h5>
            <p class="text-muted">Webhook-триггер позволяет NocoBase принимать данные из внешних систем и автоматически выполнять нужные действия.<br>Например, когда пользователь оставляет новый отзыв во внешней службе поддержки, данные передаются в NocoBase и создают заявку автоматически.</p>
          </div>
        </div><!--end col-->
        <div class="col-lg-7">
          <div class="card rounded border-0 shadow ms-lg-5">
            <video controls class="rounded shadow">
              <source src="https://static-docs.nocobase.com/WF-5.4-EN.mp4" type="video/mp4">
            </video>
          </div>
        </div><!--end col-->
      </div><!--end row-->
      <div class="row align-items-top mt-100">
        <div class="col-lg-5 col-md-5">
          <div class="section-title">
            <h5 class="mb-4">Интеграция с <span class="text-primary">внешними системами</span> через HTTP Request</h5>
            <p class="text-muted">Узел HTTP Request позволяет NocoBase активно взаимодействовать с внешними системами: вызывать API, автоматически отправлять данные и получать ответы.<br>Например, при обновлении статуса доставки в NocoBase информация о заказе может автоматически уходить в логистическую платформу.</p>
          </div>
        </div><!--end col-->
        <div class="col-lg-7">
          <div class="card rounded border-0 shadow ms-lg-5">
            <video controls class="rounded shadow">
              <source src="https://static-docs.nocobase.com/WF-5.5-EN.mp4" type="video/mp4">
            </video>
          </div>
        </div><!--end col-->
      </div><!--end row-->
      <div class="row align-items-top mt-100">
        <div class="col-lg-5 col-md-5">
          <div class="section-title">
            <h5 class="mb-4"><span class="text-primary">Отладка</span>, контроль версий и отслеживание выполнения</h5>
            <p class="text-muted">Workflow в NocoBase поддерживают ручную отладку, контроль версий и просмотр журналов, облегчая разработку, тестирование и анализ выполнения.</p>
          </div>
        </div><!--end col-->
        <div class="col-lg-7">
          <div class="card rounded border-0 shadow ms-lg-5">
            <video controls class="rounded shadow">
              <source src="https://static-docs.nocobase.com/WF-5.7-EN.mp4" type="video/mp4">
            </video>
          </div>
        </div><!--end col-->
      </div><!--end row-->
    </div><!--end container-->
  </section><!--end section-->
  <!-- Highlights End -->
</Layout>